{
  "appId": "com.yokaijump.game",
  "appName": "Yokai Jump",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#1a1a2e",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1a1a2e",
      "overlaysWebView": true
    },
    "ScreenOrientation": {
      "orientation": "portrait"
    },
    "Haptics": {
      "enabled": true
    }
  }
}
